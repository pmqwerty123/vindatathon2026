import sys, warnings, os, json
warnings.filterwarnings('ignore')

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import matplotlib.dates as mdates
import matplotlib.gridspec as gridspec
import seaborn as sns
from scipy import stats
from scipy.signal import periodogram
from statsmodels.tsa.stattools import acf, pacf, adfuller, kpss
from statsmodels.tsa.seasonal import STL
from statsmodels.graphics.tsaplots import plot_acf, plot_pacf

np.random.seed(42)

PALETTE = ['#2563eb', '#16a34a', '#dc2626', '#d97706', '#7c3aed', '#0891b2', '#be185d']

plt.rcParams.update({
    'figure.dpi': 130,
    'figure.facecolor': 'white',
    'axes.facecolor': '#fafafa',
    'axes.spines.top': False,
    'axes.spines.right': False,
    'axes.titlesize': 13,
    'axes.titleweight': 'bold',
    'axes.labelsize': 11,
    'xtick.labelsize': 9,
    'ytick.labelsize': 9,
    'legend.fontsize': 9,
    'grid.alpha': 0.35,
    'axes.grid': True,
    'grid.linestyle': '--',
})

FIG_DIR = '/home/claude/figures/'
DATA_DIR = '/home/claude/data/'
os.makedirs(FIG_DIR, exist_ok=True)

# ── Load all tables
def safe_load(name, parse_dates=None):
    path = f'{DATA_DIR}{name}.csv'
    try:
        df = pd.read_csv(path, parse_dates=parse_dates, low_memory=False)
        print(f'  ✓ {name:20s} {df.shape[0]:>8,} rows × {df.shape[1]} cols')
        return df
    except FileNotFoundError:
        print(f'  ✗ {name} NOT FOUND')
        return None

print('Loading tables...')
sales       = safe_load('sales',       parse_dates=['Date'])
customers   = safe_load('customers',   parse_dates=['signup_date'])
orders      = safe_load('orders',      parse_dates=['order_date'])
order_items = safe_load('order_items')
products    = safe_load('products')
promotions  = safe_load('promotions',  parse_dates=['start_date','end_date'])
shipments   = safe_load('shipments',   parse_dates=['ship_date','delivery_date'])
returns     = safe_load('returns',     parse_dates=['return_date'])
reviews     = safe_load('reviews',     parse_dates=['review_date'])
payments    = safe_load('payments',    parse_dates=['payment_date'])
geography   = safe_load('geography')
inventory   = safe_load('inventory',   parse_dates=['snapshot_date'])
web_traffic = safe_load('web_traffic', parse_dates=['date'])

sales = sales.sort_values('Date').reset_index(drop=True)
sales['month'] = sales['Date'].dt.month
sales['year'] = sales['Date'].dt.year
sales['dow'] = sales['Date'].dt.dayofweek

print('\nAll loaded ✓')

# ══════════════════════════════════════════════════════
# FIG 1: Monthly Revenue & Gross Margin
# ══════════════════════════════════════════════════════
monthly = sales.resample('ME', on='Date')[['Revenue','COGS']].sum()
monthly['GrossProfit'] = monthly['Revenue'] - monthly['COGS']
monthly['Margin%'] = monthly['GrossProfit'] / monthly['Revenue'] * 100

fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(15, 7), sharex=True)
ax1.bar(monthly.index, monthly['Revenue']/1e9, width=25, color=PALETTE[0], alpha=0.75, label='Revenue (B VND)')
ax1.set_ylabel('Revenue (Billion VND)')
ax1.set_title('Monthly Revenue (2012–2022) — Structural Break visible at 2018→2019')
ax1.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:.1f}B'))
ax1.axvspan(pd.Timestamp('2018-01-01'), pd.Timestamp('2019-12-31'), alpha=0.07, color='red', label='Break zone')
ax1.legend()
ax2.plot(monthly.index, monthly['Margin%'], color=PALETTE[2], lw=1.5)
ax2.fill_between(monthly.index, monthly['Margin%'], alpha=0.2, color=PALETTE[2])
ax2.axhline(monthly['Margin%'].mean(), linestyle='--', color='gray', alpha=0.7, label=f'Mean {monthly["Margin%"].mean():.1f}%')
ax2.set_ylabel('Gross Margin %')
ax2.legend()
ax2.set_title('Monthly Gross Margin %')
plt.tight_layout()
plt.savefig(f'{FIG_DIR}01_monthly_revenue_margin.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 1 done')

# ══════════════════════════════════════════════════════
# FIG 2: Annual Revenue, COGS, Gross Profit
# ══════════════════════════════════════════════════════
annual = sales.resample('YE', on='Date')[['Revenue','COGS']].sum()
annual.index = annual.index.year
annual['GrossProfit'] = annual['Revenue'] - annual['COGS']
annual['Margin%'] = annual['GrossProfit'] / annual['Revenue'] * 100
annual['YoY%'] = annual['Revenue'].pct_change() * 100

fig, ax = plt.subplots(figsize=(13, 5))
x = np.arange(len(annual))
ax.bar(x, annual['COGS']/1e9, width=0.6, color=PALETTE[2], alpha=0.7, label='COGS')
ax.bar(x, annual['GrossProfit']/1e9, width=0.6, bottom=annual['COGS']/1e9, color=PALETTE[1], alpha=0.8, label='Gross Profit')
for i, (yr, row) in enumerate(annual.iterrows()):
    ax.text(i, row['Revenue']/1e9 + 0.03, f"{row['Margin%']:.1f}%", ha='center', va='bottom', fontsize=8, fontweight='bold')
    if i > 0:
        sign = '+' if row['YoY%'] > 0 else ''
        color = PALETTE[1] if row['YoY%'] > 0 else PALETTE[2]
        ax.text(i, row['Revenue']/1e9 * 0.5, f"{sign}{row['YoY%']:.1f}%", ha='center', va='center', fontsize=8, color=color, fontweight='bold')
ax.set_xticks(x)
ax.set_xticklabels(annual.index)
ax.set_title('Annual Revenue, COGS & Gross Profit (2012–2022)')
ax.set_ylabel('Billion VND')
ax.legend()
plt.tight_layout()
plt.savefig(f'{FIG_DIR}02_annual_revenue.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 2 done')

# ══════════════════════════════════════════════════════
# FIG 3: Daily Revenue Distribution
# ══════════════════════════════════════════════════════
fig, axes = plt.subplots(1, 3, figsize=(16, 4))
axes[0].hist(sales['Revenue']/1e6, bins=80, color=PALETTE[0], edgecolor='white', lw=0.3, alpha=0.85)
axes[0].axvline(sales['Revenue'].median()/1e6, color=PALETTE[2], linestyle='--', label=f'Median {sales["Revenue"].median()/1e6:.0f}M')
axes[0].axvline(sales['Revenue'].mean()/1e6, color=PALETTE[3], linestyle=':', label=f'Mean {sales["Revenue"].mean()/1e6:.0f}M')
axes[0].set_title('Distribution of Daily Revenue')
axes[0].set_xlabel('Revenue (Million VND)')
axes[0].set_ylabel('Days')
axes[0].legend()

log_rev = np.log(sales['Revenue'])
axes[1].hist(log_rev, bins=60, color=PALETTE[4], edgecolor='white', lw=0.3, alpha=0.85)
stat, pval = stats.normaltest(log_rev)
axes[1].set_title(f'log(Revenue) — normality test p={pval:.3f}')
axes[1].set_xlabel('log(Revenue)')
mu, sigma = log_rev.mean(), log_rev.std()
axes[1].text(0.05, 0.9, f'μ={mu:.2f}  σ={sigma:.2f}', transform=axes[1].transAxes, fontsize=10, bbox=dict(boxstyle='round', facecolor='white'))

stats.probplot(log_rev, dist='norm', plot=axes[2])
axes[2].set_title('Q-Q plot of log(Revenue)')
axes[2].get_lines()[0].set(color=PALETTE[0], markersize=2, alpha=0.5)
axes[2].get_lines()[1].set(color=PALETTE[2], lw=2)
plt.tight_layout()
plt.savefig(f'{FIG_DIR}03_daily_revenue_dist.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 3 done')

# ══════════════════════════════════════════════════════
# FIG 4: STL Decomposition
# ══════════════════════════════════════════════════════
daily_rev = sales.set_index('Date')['Revenue'].asfreq('D')
stl = STL(daily_rev, period=365, robust=True)
res = stl.fit()

fig, axes = plt.subplots(4, 1, figsize=(15, 10), sharex=True)
components = [
    (daily_rev/1e6, 'Observed Revenue (M VND)', PALETTE[0]),
    (res.trend/1e6, 'Trend (M VND)', PALETTE[1]),
    (res.seasonal/1e6, 'Seasonal (M VND)', PALETTE[4]),
    (res.resid/1e6, 'Residual (M VND)', PALETTE[2]),
]
for ax, (data, label, color) in zip(axes, components):
    ax.plot(data.index, data.values, lw=0.8, color=color)
    ax.set_ylabel(label, fontsize=9)
    ax.fill_between(data.index, data.values, alpha=0.1, color=color)
axes[0].set_title('STL Decomposition of Daily Revenue (period=365 days, robust=True)')
plt.tight_layout()
plt.savefig(f'{FIG_DIR}04_stl_decomposition.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 4 done')

# ══════════════════════════════════════════════════════
# FIG 5: ACF / PACF
# ══════════════════════════════════════════════════════
fig, axes = plt.subplots(2, 2, figsize=(14, 8))
plot_acf(daily_rev, lags=400, ax=axes[0,0], alpha=0.05, color=PALETTE[0])
axes[0,0].set_title('ACF — Raw Revenue (up to lag 400)')
plot_pacf(daily_rev, lags=50, ax=axes[0,1], alpha=0.05, color=PALETTE[1])
axes[0,1].set_title('PACF — Raw Revenue (up to lag 50)')
log_rev_series = np.log(daily_rev)
log_diff = log_rev_series.diff().dropna()
plot_acf(log_diff, lags=400, ax=axes[1,0], alpha=0.05, color=PALETTE[4])
axes[1,0].set_title('ACF — Differenced log(Revenue)')
plot_pacf(log_diff, lags=50, ax=axes[1,1], alpha=0.05, color=PALETTE[2])
axes[1,1].set_title('PACF — Differenced log(Revenue)')
for lag, label in [(7,'Weekly'), (30,'Monthly'), (365,'Annual')]:
    for ax in [axes[0,0], axes[1,0]]:
        ax.axvline(lag, color='red', alpha=0.4, linestyle=':', lw=1)
        ax.text(lag+2, 0.05, label, fontsize=7, color='red', rotation=90)
plt.tight_layout()
plt.savefig(f'{FIG_DIR}05_acf_pacf.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 5 done')

# ══════════════════════════════════════════════════════
# FIG 6: Periodogram
# ══════════════════════════════════════════════════════
freqs, power = periodogram(np.log(daily_rev.values), fs=1.0)
fig, ax = plt.subplots(figsize=(14, 4))
periods = 1 / freqs[1:]
power_db = 10 * np.log10(power[1:] + 1e-20)
ax.plot(periods, power_db, lw=0.7, color=PALETTE[0], alpha=0.8)
ax.set_xscale('log')
ax.set_title('Periodogram of log(Revenue) — dominant cycles')
ax.set_xlabel('Period (days, log scale)')
ax.set_ylabel('Power (dB)')
for p, label in [(7,'7d'), (30,'30d'), (91,'91d'), (182,'182d'), (365,'365d')]:
    ax.axvline(p, color=PALETTE[2], alpha=0.6, linestyle='--', lw=1)
    ax.text(p*1.05, power_db.max()*0.82, label, fontsize=8, color=PALETTE[2], rotation=90)
plt.tight_layout()
plt.savefig(f'{FIG_DIR}06_periodogram.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 6 done')

# ══════════════════════════════════════════════════════
# FIG 7: Monthly Seasonal Shape
# ══════════════════════════════════════════════════════
monthly_shape = sales.groupby(['year','month'])['Revenue'].sum().reset_index()
monthly_shape['Rev_B'] = monthly_shape['Revenue'] / 1e9

fig, axes = plt.subplots(1, 2, figsize=(15, 5))
for yr in monthly_shape['year'].unique():
    subset = monthly_shape[monthly_shape['year'] == yr]
    alpha = 0.9 if yr >= 2019 else 0.35
    lw = 2.0 if yr >= 2019 else 0.8
    color = PALETTE[0] if yr >= 2019 else 'gray'
    axes[0].plot(subset['month'], subset['Rev_B'], marker='o', ms=3, lw=lw, alpha=alpha, color=color, label=str(yr) if yr >= 2019 else None)
axes[0].set_title('Monthly Revenue Profile — all years\n(gray=old regime, blue=2019–2022)')
axes[0].set_xlabel('Month')
axes[0].set_ylabel('Revenue (Billion VND)')
axes[0].set_xticks(range(1,13))
axes[0].set_xticklabels(['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], rotation=30)
axes[0].legend(loc='upper right', fontsize=7)

for yr in monthly_shape['year'].unique():
    subset = monthly_shape[monthly_shape['year'] == yr].copy()
    subset['norm'] = subset['Rev_B'] / subset['Rev_B'].mean()
    alpha = 0.9 if yr >= 2019 else 0.3
    lw = 2.0 if yr >= 2019 else 0.7
    color = PALETTE[0] if yr >= 2019 else 'gray'
    axes[1].plot(subset['month'], subset['norm'], marker='o', ms=3, lw=lw, alpha=alpha, color=color)
axes[1].axhline(1.0, linestyle='--', color='gray', alpha=0.6)
axes[1].set_title('Normalized Monthly Shape (each year / its mean)\nShape stability across regime shift')
axes[1].set_xlabel('Month')
axes[1].set_ylabel('Revenue / Annual Mean')
axes[1].set_xticks(range(1,13))
axes[1].set_xticklabels(['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], rotation=30)
plt.tight_layout()
plt.savefig(f'{FIG_DIR}07_seasonal_shape.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 7 done')

# ══════════════════════════════════════════════════════
# FIG 8: Day-of-Week & August Biennial Anomaly
# ══════════════════════════════════════════════════════
fig, axes = plt.subplots(1, 3, figsize=(16, 4))
recent = sales[sales['year'] >= 2019].copy()
dow_rev = recent.groupby('dow')['Revenue'].mean() / 1e6
dow_names = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']
axes[0].bar(range(7), dow_rev.values, color=PALETTE[0], alpha=0.8)
axes[0].set_xticks(range(7))
axes[0].set_xticklabels(dow_names)
axes[0].set_title('Mean Daily Revenue by Day-of-Week\n(2019–2022 regime)')
axes[0].set_ylabel('Mean Revenue (M VND)')
grand_mean = recent['Revenue'].mean() / 1e6
for i, v in enumerate(dow_rev.values):
    axes[0].text(i, v + 0.3, f'{v/grand_mean:.2f}×', ha='center', fontsize=8)
axes[0].axhline(grand_mean, linestyle='--', color=PALETTE[2], alpha=0.7, label=f'Grand mean {grand_mean:.0f}M')
axes[0].legend()

aug = sales[sales['month'] == 8].copy()
aug_annual = aug.groupby('year')['Revenue'].sum() / 1e9
years_aug = aug_annual.index.tolist()
colors_aug = [PALETTE[0] if y % 2 == 0 else PALETTE[2] for y in years_aug]
axes[1].bar(years_aug, aug_annual.values, color=colors_aug, alpha=0.85)
axes[1].set_title('August Annual Revenue (B VND)\nBlue=even year, Red=odd year')
axes[1].set_xlabel('Year')
axes[1].set_ylabel('Revenue (B VND)')
for yr, val in zip(years_aug, aug_annual.values):
    axes[1].text(yr, val + 0.5, f'{val:.0f}', ha='center', fontsize=8)

recent_aug = aug[aug['year'] >= 2019]
even_mean = recent_aug[recent_aug['year'] % 2 == 0]['Revenue'].sum() / 2 / 1e9
odd_mean  = recent_aug[recent_aug['year'] % 2 == 1]['Revenue'].sum() / 2 / 1e9
axes[2].bar(['Even years\n(2020, 2022)', 'Odd years\n(2019, 2021)'], [even_mean, odd_mean], color=[PALETTE[0], PALETTE[2]], alpha=0.85)
axes[2].set_title('August Revenue: Even vs Odd Year')
axes[2].set_ylabel('Mean August Revenue (B VND)')
for i, v in enumerate([even_mean, odd_mean]):
    axes[2].text(i, v + 0.3, f'{v:.1f}B', ha='center', fontsize=10, fontweight='bold')
plt.tight_layout()
plt.savefig(f'{FIG_DIR}08_dow_august_biennial.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 8 done')

# ══════════════════════════════════════════════════════
# FIG 9: Rolling Statistics & Volatility
# ══════════════════════════════════════════════════════
fig, axes = plt.subplots(3, 1, figsize=(15, 10), sharex=True)
roll30 = daily_rev.rolling(30, center=True).mean()
roll365 = daily_rev.rolling(365, center=True).mean()
axes[0].plot(daily_rev.index, daily_rev/1e6, lw=0.5, color='gray', alpha=0.5, label='Daily')
axes[0].plot(roll30.index, roll30/1e6, lw=1.5, color=PALETTE[3], label='30d MA')
axes[0].plot(roll365.index, roll365/1e6, lw=2.5, color=PALETTE[0], label='365d MA')
axes[0].set_ylabel('Revenue (M VND)')
axes[0].set_title('Rolling Mean: 30-day and 365-day')
axes[0].legend()

roll_cv = daily_rev.rolling(90).std() / daily_rev.rolling(90).mean() * 100
axes[1].plot(roll_cv.index, roll_cv.values, lw=1, color=PALETTE[4], alpha=0.8)
axes[1].fill_between(roll_cv.index, roll_cv.values, alpha=0.15, color=PALETTE[4])
axes[1].set_ylabel('90d Rolling CV %')
axes[1].set_title('Rolling Coefficient of Variation (90-day window)')
axes[1].axhline(roll_cv.mean(), linestyle='--', color='gray', label=f'Mean CV = {roll_cv.mean():.1f}%')
axes[1].legend()

yoy = daily_rev.pct_change(365) * 100
colors_yoy = [PALETTE[1] if v > 0 else PALETTE[2] for v in yoy.fillna(0).values]
axes[2].bar(yoy.index, yoy.values, width=1, color=colors_yoy, alpha=0.6)
axes[2].axhline(0, color='black', lw=0.8)
axes[2].set_ylabel('YoY Growth %')
axes[2].set_title('Year-over-Year Growth Rate (daily, 365-day lag)')
axes[2].set_ylim(-120, 200)
plt.tight_layout()
plt.savefig(f'{FIG_DIR}09_rolling_volatility.png', bbox_inches='tight', dpi=150)
plt.close()
print('Fig 9 done')

# ══════════════════════════════════════════════════════
# FIG 10: New Customer Acquisition
# ══════════════════════════════════════════════════════
customers['signup_month'] = customers['signup_date'].dt.to_period('M').dt.to_timestamp()
new_cust = customers.groupby('signup_month').size().rename('new_customers')
fig, axes = plt.subplots(1, 2, figsize=(15, 4))
axes[0].plot(new_cust.index, new_cust.values, color=PALETTE[1], lw=1.5)
axes[0].fill_between(new_cust.index, new_cust.values, alpha=0.15, color=PALETTE[1])
rolling = new_cust.rolling(12, center=True).mean()
axes[0].plot(rolling.index, rolling.values, color=PALETTE[2], lw=2.5, linestyle='--', label='12M rolling avg')
axes[0].set_title(f'Monthly New Customer Signups | Total: {len(customers):,}')
axes[0].set_ylabel('New Customers')
axes[0].legend()
axes[1].plot(new_cust.index, new_cust.cumsum(), color=PALETTE[0], lw=2)
axes[1].set_title('Cumulative Customer Base')
axes[1].set_ylabel('Total Customers')
plt.tight_layout()
plt.savefig(f'{FIG_DIR}10_new_customers.png', bbox_inches='tight', dpi=150)
