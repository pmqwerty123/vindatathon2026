    sorted_opc = opc.sort_values()
    cdf = np.arange(1, len(sorted_opc)+1) / len(sorted_opc) * 100
    axes[1].plot(sorted_opc.values, cdf, color=PALETTE[4], lw=2)
    axes[1].set_xscale('log')
    axes[1].set_title('CDF of Orders per Customer')
    axes[1].set_xlabel('Number of Orders')
    axes[1].set_ylabel('Cumulative % of Customers')

    # Lorenz curve for revenue concentration
    order_vals = orders.merge(order_items.groupby('order_id')['quantity'].sum().rename('items') if order_items is not None else pd.Series([], name='items'), on='order_id', how='left')
    rev_per_cust = orders.groupby('customer_id')['order_id'].count()
    sorted_r = np.sort(rev_per_cust.values)
    lorenz = np.cumsum(sorted_r) / sorted_r.sum()
    pop_frac = np.arange(1, len(sorted_r)+1) / len(sorted_r)
    axes[2].plot(pop_frac, lorenz, color=PALETTE[0], lw=2, label='Lorenz curve')
    axes[2].plot([0,1],[0,1], linestyle='--', color='gray', label='Perfect equality')
    gini = 1 - 2 * np.trapz(lorenz, pop_frac)
    axes[2].text(0.05, 0.85, f'Gini = {gini:.3f}', transform=axes[2].transAxes, fontsize=11,
                 bbox=dict(boxstyle='round', facecolor='white'))
    axes[2].set_title('Order Concentration (Lorenz Curve)')
    axes[2].set_xlabel('Cumulative % Customers')
    axes[2].set_ylabel('Cumulative % Orders')
    axes[2].legend()

    plt.tight_layout()
    plt.savefig(f'{FIG_DIR}11_order_frequency.png', bbox_inches='tight', dpi=150)
