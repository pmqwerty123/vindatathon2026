cells.append(code("""# ── Load all tables
DATA_DIR = '../data/'

def safe_load(name, parse_dates=None):
    path = f'{DATA_DIR}{name}.csv'
    try:
        df = pd.read_csv(path, parse_dates=parse_dates, low_memory=False)
        print(f'  ✓ {name:20s} {df.shape[0]:>8,} rows × {df.shape[1]} cols')
        return df
    except FileNotFoundError:
        print(f'  ✗ {name} NOT FOUND — skipping')
        return None

print('Loading tables...')
sales       = safe_load('sales',       parse_dates=['Date'])
customers   = safe_load('customers',   parse_dates=['signup_date'])
orders      = safe_load('orders',      parse_dates=['order_date'])
order_items = safe_load('order_items')
products    = safe_load('products')
promotions  = safe_load('promotions',  parse_dates=['start_date','end_date'])
shipments   = safe_load('shipments',   parse_dates=['ship_date','delivery_date'])
returns     = safe_load('returns',     parse_dates=['return_date'])
reviews     = safe_load('reviews',     parse_dates=['review_date'])
payments    = safe_load('payments',    parse_dates=['payment_date'])
geography   = safe_load('geography')
inventory   = safe_load('inventory',   parse_dates=['snapshot_date'])
web_traffic = safe_load('web_traffic', parse_dates=['date'])

if sales is not None:
    sales = sales.sort_values('Date').reset_index(drop=True)
    sales['month'] = sales['Date'].dt.month
    sales['year']  = sales['Date'].dt.year
    sales['dow']   = sales['Date'].dt.dayofweek

print('\\nAll tables loaded ✓')
"""))

