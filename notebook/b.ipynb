cells.append(code("""# ── 1.3 Sales series completeness
if sales is not None:
    full_range = pd.date_range(sales['Date'].min(), sales['Date'].max(), freq='D')
    missing_dates = full_range.difference(sales['Date'])
    zero_rev = (sales['Revenue'] <= 0).sum()
    neg_cogs = (sales['COGS'] < 0).sum()

    print(f'Date range     : {sales[\"Date\"].min().date()} → {sales[\"Date\"].max().date()}')
    print(f'Total days     : {len(sales):,}')
    print(f'Expected days  : {len(full_range):,}')
    print(f'Missing dates  : {len(missing_dates)} ✓' if len(missing_dates)==0 else f'Missing dates  : {list(missing_dates[:5])}')
    print(f'Zero/neg Rev   : {zero_rev}')
    print(f'Negative COGS  : {neg_cogs}')
    print(f'\\nSales describe:')
    display(sales[['Revenue','COGS']].describe().applymap(lambda x: f'{x:,.0f}'))

# ── 1.4 Foreign Key Validation
def fk_check(child_name, child_col, parent_name, parent_col, child_df, parent_df):
    if child_df is None or parent_df is None: return
    child_vals  = set(child_df[child_col].dropna())
    parent_vals = set(parent_df[parent_col].dropna())
    orphans     = child_vals - parent_vals
    coverage    = 1 - len(orphans) / len(child_vals) if child_vals else 1.0
    status      = '✓' if coverage > 0.99 else '⚠️' if coverage > 0.95 else '✗'
    print(f'{status} {child_name}.{child_col:15s} → {parent_name}.{parent_col:15s} '
          f'coverage={coverage*100:.1f}%  orphans={len(orphans):,}')

print('\\n=== Foreign Key Coverage ===')
fk_check('orders',      'customer_id', 'customers', 'customer_id', orders,     customers)
fk_check('order_items', 'order_id',    'orders',    'order_id',    order_items, orders)
fk_check('order_items', 'product_id',  'products',  'product_id',  order_items, products)
fk_check('orders',      'zip',         'geography', 'zip',         orders,      geography)
fk_check('shipments',   'order_id',    'orders',    'order_id',    shipments,   orders)
fk_check('returns',     'order_id',    'orders',    'order_id',    returns,     orders)
fk_check('reviews',     'order_id',    'orders',    'order_id',    reviews,     orders)
fk_check('payments',    'order_id',    'orders',    'order_id',    payments,    orders)
"""))

