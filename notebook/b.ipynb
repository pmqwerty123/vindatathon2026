cells.append(md("## 8. Preprocessing & Feature Engineering"))

cells.append(code("""# ── 8.1 Preprocessing Pipeline

def compute_tet_dates(years):
    tet_approx = {
        2012: '2012-01-23', 2013: '2013-02-10', 2014: '2014-01-31',
        2015: '2015-02-19', 2016: '2016-02-08', 2017: '2017-01-28',
        2018: '2018-02-16', 2019: '2019-02-05', 2020: '2020-01-25',
        2021: '2021-02-12', 2022: '2022-02-01', 2023: '2023-01-22',
        2024: '2024-02-10',
    }
    return {y: pd.Timestamp(d) for y, d in tet_approx.items() if y in years}

def is_vn_holiday(date):
    m, d = date.month, date.day
    holidays = [(1,1),(4,30),(5,1),(9,2)]
    return int((m, d) in holidays)

def days_to_tet(date, tet_map):
    year = date.year
    tet = tet_map.get(year, tet_map.get(year-1))
    if tet is None: return np.nan
    return (date - tet).days

print('Building feature matrix...')
all_years = list(range(sales['Date'].dt.year.min(), sales['Date'].dt.year.max() + 2))
tet_map = compute_tet_dates(all_years)

df = sales[['Date','Revenue','COGS']].copy()
df = df.sort_values('Date').reset_index(drop=True)

# Calendar features
df['year']          = df['Date'].dt.year
df['month']         = df['Date'].dt.month
df['day_of_month']  = df['Date'].dt.day
df['day_of_week']   = df['Date'].dt.dayofweek
df['day_of_year']   = df['Date'].dt.dayofyear
df['week_of_year']  = df['Date'].dt.isocalendar().week.astype(int)
df['quarter']       = df['Date'].dt.quarter
df['is_weekend']    = (df['day_of_week'] >= 5).astype(int)
df['is_month_end']  = df['Date'].dt.is_month_end.astype(int)
df['is_month_start']= df['Date'].dt.is_month_start.astype(int)
df['is_quarter_end']= df['Date'].dt.is_quarter_end.astype(int)
df['is_quarter_start']= df['Date'].dt.is_quarter_start.astype(int)
df['is_year_end']   = df['Date'].dt.is_year_end.astype(int)
df['is_year_start'] = df['Date'].dt.is_year_start.astype(int)

# Cyclical encodings
for col, period in [('month',12), ('day_of_week',7), ('week_of_year',52), ('day_of_year',365)]:
    df[f'{col}_sin'] = np.sin(2 * np.pi * df[col] / period)
    df[f'{col}_cos'] = np.cos(2 * np.pi * df[col] / period)

# Regime flags
df['is_recent_regime'] = (df['year'] >= 2019).astype(int)
df['is_even_year']     = (df['year'] % 2 == 0).astype(int)
df['is_august']        = (df['month'] == 8).astype(int)
df['is_aug_even']      = ((df['month'] == 8) & (df['year'] % 2 == 0)).astype(int)
df['is_aug_odd']       = ((df['month'] == 8) & (df['year'] % 2 == 1)).astype(int)

# Vietnamese holidays
df['is_vn_holiday'] = df['Date'].apply(is_vn_holiday)
df['days_to_tet']   = df['Date'].apply(lambda d: days_to_tet(d, tet_map))
df['is_tet_week']   = (df['days_to_tet'].abs() <= 7).astype(int)
df['is_tet_month']  = (df['days_to_tet'].between(-30, 30)).astype(int)
df['tet_countdown'] = df['days_to_tet'].clip(lower=-60, upper=60)

# Log Revenue
df['log_revenue'] = np.log(df['Revenue'])

print(f'Feature matrix shape: {df.shape}')
display(df.head(3))
"""))

cells.append(code("""# ── 8.2 Long-Horizon Lag Features (leakage-safe)
print('Computing lag features...')

for lag in [364, 365, 366, 548, 730]:
    df[f'rev_lag_{lag}']     = df['Revenue'].shift(lag)
    df[f'log_rev_lag_{lag}'] = df['log_revenue'].shift(lag)

# Rolling stats at lag anchor points
for roll in [7, 14, 30, 60, 90]:
    for base_lag in [365, 548, 730]:
        shifted = df['Revenue'].shift(base_lag)
        df[f'rev_roll{roll}_lag{base_lag}'] = shifted.rolling(roll, min_periods=1).mean()
        df[f'rev_std{roll}_lag{base_lag}']  = shifted.rolling(roll, min_periods=1).std()
        log_shifted = df['log_revenue'].shift(base_lag)
        df[f'log_rev_roll{roll}_lag{base_lag}'] = log_shifted.rolling(roll, min_periods=1).mean()

# Ensemble lag (365+730 mean)
df['rev_lag_365_730_mean']     = (df['rev_lag_365'].fillna(0) + df['rev_lag_730'].fillna(0)) / 2
df['log_rev_lag_365_730_mean'] = (df['log_rev_lag_365'].fillna(0) + df['log_rev_lag_730'].fillna(0)) / 2

# YoY ratio (today vs same day last year)
df['yoy_ratio'] = df['Revenue'] / df['rev_lag_365'].replace(0, np.nan)

print(f'Lag features added. Total columns: {df.shape[1]}')
"""))

cells.append(code("""# ── 8.3 Seasonal Lookup Features
def build_seasonal_lookups(train_df, min_year=2019, level_correct=True):
    recent = train_df[train_df['year'] >= min_year].copy()
    doy_mean   = recent.groupby('day_of_year')['Revenue'].mean().rename('seasonal_doy_mean')
    mdow_mean  = recent.groupby(['month','day_of_week'])['Revenue'].mean().rename('seasonal_month_dow_mean')
    recent['year_parity'] = recent['year'] % 2
    mparity_mean = recent.groupby(['month','year_parity'])['Revenue'].mean().rename('seasonal_month_parity_mean')
    week_mean  = recent.groupby('week_of_year')['Revenue'].mean().rename('seasonal_week_mean')
    qtr_mean   = recent.groupby('quarter')['Revenue'].mean().rename('seasonal_quarter_mean')

    if level_correct:
        last_12m = train_df[train_df['Date'] >= train_df['Date'].max() - pd.Timedelta(days=365)]
        level_factor = last_12m['Revenue'].mean() / recent['Revenue'].mean()
    else:
        level_factor = 1.0

    return {
        'doy_mean'    : doy_mean * level_factor,
        'mdow_mean'   : mdow_mean * level_factor,
        'mparity_mean': mparity_mean * level_factor,
        'week_mean'   : week_mean * level_factor,
        'qtr_mean'    : qtr_mean * level_factor,
        'level_factor': level_factor,
    }

lookups = build_seasonal_lookups(df, min_year=2019)
df['year_parity'] = df['year'] % 2
df = df.merge(lookups['doy_mean'].reset_index(), on='day_of_year', how='left')
df = df.merge(lookups['mdow_mean'].reset_index(), on=['month','day_of_week'], how='left')
df = df.merge(lookups['mparity_mean'].reset_index(), on=['month','year_parity'], how='left')
df = df.merge(lookups['week_mean'].reset_index(), on='week_of_year', how='left')
df = df.merge(lookups['qtr_mean'].reset_index(), on='quarter', how='left')

for col in ['seasonal_doy_mean','seasonal_month_dow_mean','seasonal_month_parity_mean',
            'seasonal_week_mean','seasonal_quarter_mean']:
    if col in df.columns:
        df[f'log_{col}'] = np.log(df[col].clip(lower=1))

print(f'Seasonal lookups added (level factor = {lookups[\"level_factor\"]:.4f}) ✓')
"""))

