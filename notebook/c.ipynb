cells.append(code("""# ── 3.4 RFM Segmentation (Recency-Frequency-Monetary) ───────────────────────
if orders is not None and order_items is not None:
    oi_rich = order_items.merge(
        products[['product_id','category','price','cogs']] if products is not None else order_items[['product_id']],
        on='product_id', how='left'
    )
    if 'unit_price' in oi_rich.columns and 'quantity' in oi_rich.columns:
        oi_rich['line_revenue'] = oi_rich['quantity'] * oi_rich['unit_price']
        if 'discount_amount' in oi_rich.columns:
            oi_rich['line_revenue'] -= oi_rich['discount_amount'].fillna(0)

    order_value = oi_rich.groupby('order_id')['line_revenue'].sum() if 'line_revenue' in oi_rich.columns else None
    
    if order_value is not None:
        orders_rfm = orders.merge(order_value.rename('order_value'), on='order_id', how='left')
        ref_date = orders_rfm['order_date'].max()
        
        rfm = orders_rfm.groupby('customer_id').agg(
            recency  = ('order_date', lambda x: (ref_date - x.max()).days),
            frequency= ('order_id', 'count'),
            monetary = ('order_value', 'sum'),
        ).dropna()
        
        # Score 1–5 each dimension
        for col in ['recency','frequency','monetary']:
            if col == 'recency':
                rfm[f'{col}_score'] = pd.qcut(rfm[col], 5, labels=[5,4,3,2,1], duplicates='drop')
            else:
                rfm[f'{col}_score'] = pd.qcut(rfm[col], 5, labels=[1,2,3,4,5], duplicates='drop')
        
        rfm['RFM_Score'] = (rfm['recency_score'].astype(int) + 
                            rfm['frequency_score'].astype(int) + 
                            rfm['monetary_score'].astype(int))
        
        def segment(row):
            r, f, m = int(row['recency_score']), int(row['frequency_score']), int(row['monetary_score'])
            if r >= 4 and f >= 4 and m >= 4: return 'Champions'
            elif r >= 3 and f >= 3: return 'Loyal'
            elif r >= 4: return 'Recent'
            elif f >= 3: return 'At Risk'
            else: return 'Lost'
        
        rfm['segment'] = rfm.apply(segment, axis=1)
        
        fig, axes = plt.subplots(1, 2, figsize=(14, 5))
        
        # Segment distribution
        seg_counts = rfm['segment'].value_counts()
        axes[0].bar(seg_counts.index, seg_counts.values, 
                    color=[PALETTE[i] for i in range(len(seg_counts))], alpha=0.85)
        axes[0].set_title('RFM Customer Segments')
        axes[0].set_ylabel('Customers')
        for i, (seg, cnt) in enumerate(seg_counts.items()):
            axes[0].text(i, cnt + 50, f'{cnt/len(rfm)*100:.1f}%', ha='center', fontsize=9)
        
        # Revenue by segment
        seg_rev = rfm.groupby('segment')['monetary'].sum().sort_values(ascending=False)
        axes[1].barh(seg_rev.index, seg_rev.values / 1e9, color=PALETTE[:len(seg_rev)], alpha=0.85)
        axes[1].set_title('Total Revenue by RFM Segment (B VND)')
        axes[1].set_xlabel('Revenue (Billion VND)')
        
        plt.tight_layout()
        plt.savefig(f'{FIG_DIR}12_rfm_segments.png', bbox_inches='tight')
        plt.show()
        
        print('RFM Summary:')
        display(rfm.groupby('segment').agg(
            n_customers=('monetary','count'),
            avg_recency =('recency','mean'),
            avg_frequency=('frequency','mean'),
            avg_monetary=('monetary','mean'),
            total_revenue=('monetary','sum')
        ).round(0).sort_values('total_revenue', ascending=False))
"""))

