cells.append(code("""# ── Load all tables ───────────────────────────────────────────────────────────
# Adjust DATA_DIR to wherever your CSVs live
DATA_DIR = '../data/'

def safe_load(name, parse_dates=None):
    path = f'{DATA_DIR}{name}.csv'
    try:
        df = pd.read_csv(path, parse_dates=parse_dates, low_memory=False)
        print(f'  ✓ {name:20s} {df.shape[0]:>8,} rows × {df.shape[1]} cols')
        return df
    except FileNotFoundError:
        print(f'  ✗ {name} NOT FOUND — skipping')
        return None

print('Loading tables...')
sales       = safe_load('sales',       parse_dates=['Date'])
customers   = safe_load('customers',   parse_dates=['signup_date'])
orders      = safe_load('orders',      parse_dates=['order_date'])
order_items = safe_load('order_items')
products    = safe_load('products')
promotions  = safe_load('promotions',  parse_dates=['start_date','end_date'])
shipments   = safe_load('shipments',   parse_dates=['ship_date','delivery_date'])
returns     = safe_load('returns',     parse_dates=['return_date'])
reviews     = safe_load('reviews',     parse_dates=['review_date'])
payments    = safe_load('payments',    parse_dates=['payment_date'])
geography   = safe_load('geography')
inventory   = safe_load('inventory',   parse_dates=['snapshot_date'])
web_traffic = safe_load('web_traffic', parse_dates=['date'])

# Sort sales by date
if sales is not None:
    sales = sales.sort_values('Date').reset_index(drop=True)

print('\\nAll tables loaded ✓')
"""))

# ─── SECTION 1: DATA QUALITY AUDIT ─────────────────────────────────────────
cells.append(md("## 1. Data Quality Audit"))

cells.append(code("""# ── 1.1 Comprehensive table audit ────────────────────────────────────────────
def audit_table(name, df):
    if df is None: return None
    date_cols = [c for c in df.columns if 'date' in c.lower() or c == 'Date']
    date_range = 'N/A'
    for dc in date_cols:
        try:
            date_range = f\"{df[dc].min().date()} → {df[dc].max().date()}\"
            break
        except: pass
    missing_pct = df.isna().mean().mul(100).round(1)
    top_missing = missing_pct[missing_pct > 0].sort_values(ascending=False).to_dict()
    return {
        'table'       : name,
        'rows'        : f\"{df.shape[0]:,}\",
        'cols'        : df.shape[1],
        'mem_MB'      : round(df.memory_usage(deep=True).sum() / 1e6, 1),
        'date_range'  : date_range,
        'null_cols'   : len(top_missing),
        'top_missing' : str({k: f'{v}%' for k, v in list(top_missing.items())[:3]}) if top_missing else '—',
        'duplicates'  : int(df.duplicated().sum()),
    }

tables = {
    'sales': sales, 'customers': customers, 'orders': orders,
    'order_items': order_items, 'products': products, 'promotions': promotions,
    'shipments': shipments, 'returns': returns, 'reviews': reviews,
    'payments': payments, 'geography': geography,
    'inventory': inventory, 'web_traffic': web_traffic,
}

audit_rows = [audit_table(k, v) for k, v in tables.items() if v is not None]
quality_df = pd.DataFrame(audit_rows)
pd.set_option('display.max_colwidth', 60)
display(quality_df.set_index('table'))
"""))

