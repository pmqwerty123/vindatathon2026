log_diff = log_rev_series.diff().dropna()
plot_acf(log_diff, lags=400, ax=axes[1,0], alpha=0.05, color=PALETTE[4])
axes[1,0].set_title('ACF — Differenced log(Revenue)')

plot_pacf(log_diff, lags=50, ax=axes[1,1], alpha=0.05, color=PALETTE[2])
axes[1,1].set_title('PACF — Differenced log(Revenue)')

# Annotate key lags
for lag, label in [(7,'Weekly'), (30,'Monthly'), (365,'Annual')]:
    for ax in [axes[0,0], axes[1,0]]:
        ax.axvline(lag, color='red', alpha=0.4, linestyle=':', lw=1)
        ax.text(lag+2, 0.05, label, fontsize=7, color='red', rotation=90)

plt.tight_layout()
plt.savefig(f'{FIG_DIR}05_acf_pacf.png', bbox_inches='tight')
plt.show()

# Key autocorrelation values
acf_vals = acf(daily_rev, nlags=730, fft=True)
for lag in [1, 7, 30, 90, 180, 365, 548, 730]:
    print(f'  ACF lag-{lag:4d}: {acf_vals[lag]:+.4f}')
"""))

cells.append(code("""# ── 2.6 Stationarity Tests ───────────────────────────────────────────────────
print('=== Stationarity Tests on log(Revenue) ===\\n')
series = np.log(daily_rev)

# ADF
adf_stat, adf_p, _, _, adf_crit, _ = adfuller(series, autolag='AIC')
print(f'Augmented Dickey-Fuller:')
print(f'  Statistic : {adf_stat:.4f}')
print(f'  p-value   : {adf_p:.6f}')
print(f'  Critical  : {adf_crit}')
print(f'  → {"Stationary ✓" if adf_p < 0.05 else "NON-STATIONARY ✗"}\\n')

# KPSS
kpss_stat, kpss_p, _, kpss_crit = kpss(series, regression='ct', nlags='auto')
print(f'KPSS (trend-stationary):')
print(f'  Statistic : {kpss_stat:.4f}')
print(f'  p-value   : {kpss_p:.4f}')
print(f'  Critical  : {kpss_crit}')
print(f'  → {"Trend-stationary ✓" if kpss_p > 0.05 else "Evidence of unit root"}')
"""))

cells.append(code("""# ── 2.7 Periodogram — identify dominant cycles ───────────────────────────────
